  "description": "Sitio web de Uno de Miga con menu, boxes para oficinas, catering y votacion de sabores.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "start:test": "powershell -Command \"$env:REDIS_KEY_PREFIX='test:'; $env:ALLOW_TEST_DATA_RESET='true'; node server.js\"",
